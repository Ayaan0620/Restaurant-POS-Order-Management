# Copy this file to ".env" and fill in your values.
# Restart `npm run dev` after editing.
#
# NOTE: never put real secrets in THIS file — it is committed to the repo.
# Real values go in ".env", which is git-ignored.

# --- Supabase ---
# Settings -> API in your Supabase project.
# The anon/publishable key is safe to be public; the service_role key is NOT —
# never put service_role in any VITE_ variable (it would ship to the browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Per-view PINs (placeholders — choose your own in .env) ---
VITE_CASHIER_PIN=0000
VITE_PICKUP_PIN=0000
VITE_KITCHEN_PIN=0000
VITE_REPORTS_PIN=0000
