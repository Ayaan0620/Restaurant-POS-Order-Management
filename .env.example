# Copy this file to ".env" and fill in your values.
# Restart `npm run dev` after editing.
#
# NOTE: never put real secrets in THIS file — it is committed to the repo.
# Real values go in ".env", which is git-ignored.

# --- Supabase ---
# Settings -> API in your Supabase project.
# The anon/publishable key is safe to be public; the service_role key is NOT —
# never put service_role in any VITE_ variable (it would ship to the browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Per-view PINs ---
# RECOMMENDED: store a SHA-256 HASH of the PIN so the plaintext never ships in
# the app. Generate one with:  npm run hash-pin -- 1234
# Then set the *_PIN_HASH variables (leave the plaintext *_PIN ones unset):
VITE_CASHIER_PIN_HASH=
VITE_PICKUP_PIN_HASH=
VITE_KITCHEN_PIN_HASH=
VITE_REPORTS_PIN_HASH=
#
# SIMPLE (less secure — plaintext is readable in the built JS): use these instead.
# VITE_CASHIER_PIN=0000
# VITE_PICKUP_PIN=0000
# VITE_KITCHEN_PIN=0000
# VITE_REPORTS_PIN=0000
